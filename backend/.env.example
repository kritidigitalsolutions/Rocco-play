# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy these into your Vercel project dashboard:
# Vercel → Project Settings → Environment Variables
# ============================================================

# --- MongoDB ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# --- JWT ---
JWT_SECRET=<your-secret-key-min-32-chars>
JWT_EXPIRE=7h

# --- BunnyCDN ---
BUNNY_ACCESS_KEY=<your-bunny-access-key>

# --- 2Factor OTP (optional) ---
TWO_FACTOR_API_KEY=<your-2factor-api-key>

# --- Email (Nodemailer) ---
EMAIL=<your-gmail>
EMAIL_PASS=<your-gmail-app-password>

# --- CORS: Your deployed frontend URL (e.g. on Vercel) ---
FRONTEND_URL=https://your-admin-frontend.vercel.app

# --- Node Environment (set to "production" on Vercel) ---
NODE_ENV=production
